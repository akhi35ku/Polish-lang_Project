# ---------- Server ----------
PORT=5000
NODE_ENV=development

# Frontend origin allowed by CORS (comma-separate multiple origins)
CLIENT_URL=http://localhost:5173

# ---------- Database (Supabase PostgreSQL) ----------
# Supabase: Project Settings -> Database -> Connection string -> URI (use the "Transaction" pooler URL for serverless,
# or the direct connection for Render/Railway). Add ?pgbouncer=true&connection_limit=1 if using the pooler.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# ---------- JWT ----------
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES=1d
JWT_REMEMBER_EXPIRES=30d
JWT_RESET_EXPIRES=15m

# ---------- Email (Nodemailer SMTP) ----------
# Gmail: use an App Password (Google Account -> Security -> 2-Step -> App passwords)
# Leave SMTP_HOST empty in development to log emails to the console instead of sending.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Auth App <no-reply@authapp.com>"

# ---------- OTP ----------
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
