              "raw": "{{baseUrl}}/api/admin/tickets/{{ticketId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "tickets",
                "{{ticketId}}",
                "status"
              ]
            },
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CLOSED\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Recent Logins",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
